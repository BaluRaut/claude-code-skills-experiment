{
  "permissions": {
    "allow": [
      "Bash(npm install)",
      "Bash(npm run test:*)",
      "Bash(npm test)",
      "Bash(npm run typecheck)",
      "Bash(npm run build)",
      "Bash(npm run format)",
      "Bash(npx vitest:*)",
      "Bash(npx tsc:*)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '.tool_input.file_path' | { read f; case \"$f\" in *.ts|*.tsx|*.json|*.css) npx prettier --write \"$f\" >/dev/null 2>&1 || true ;; esac; }"
          }
        ]
      }
    ]
  }
}
